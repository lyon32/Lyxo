# Backend — voir docs/ENV_SETUP.md §1.2
# Copier en .env (jamais commité) et remplir. Secrets réels : Supabase
# Dashboard > Project Settings > API, jamais dans ce fichier.

DATABASE_URL=
DIRECT_URL=
SUPABASE_URL=https://gyslysnysrswzefmvpxw.supabase.co
# Récupérer dans Supabase Dashboard > Project Settings > API Keys —
# nécessaire pour /v1/profiles/* (lib/supabase-admin.ts, bypass RLS).
SUPABASE_SERVICE_ROLE_KEY=
# PAS utilisé par ce projet (créé après le passage de Supabase aux clés
# JWT asymétriques JWKS) — lib/auth.ts vérifie via
# {SUPABASE_URL}/auth/v1/.well-known/jwks.json, aucun secret partagé à
# fournir. Conservé en commentaire pour mémoire si un futur projet
# Supabase legacy en avait besoin.
# SUPABASE_JWT_SECRET=

# Phase 3 (billing) — laisser vide jusque-là
PAWAPAY_API_TOKEN_SANDBOX=
PAWAPAY_API_TOKEN_PROD=
PAWAPAY_CALLBACK_SIGNING_KEY=
REVENUECAT_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Vide tant qu'aucun projet Sentry n'existe — lib/sentry.ts no-op sans DSN
SENTRY_DSN=

# Branché au Bloc G (beta), pas avant
POSTHOG_API_KEY=

ADMIN_API_KEY=
PORT=3000
NODE_ENV=development
